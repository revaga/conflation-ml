# Copy this file to api_keys.env and fill in your keys.
# api_keys.env is gitignored so your keys are not committed.

# --- SLM attribute labeler (scripts/slm_attribute_labeler.py) ---
# Provider: local | groq | openai | gemini | huggingface
# Local (no API key): run model on this machine with transformers (e.g. google/gemma-3-4b-it)
# SLM_PROVIDER=local
# SLM_MODEL=google/gemma-3-4b-it

# Hugging Face router (when SLM_PROVIDER=huggingface)
# HF_TOKEN=your_huggingface_token_here
# SLM_MODEL=HuggingFaceH4/zephyr-7b-beta

# Gemini (when SLM_PROVIDER=gemini)
# GEMINI_API_KEY=your_gemini_api_key_here

# Groq (when SLM_PROVIDER=groq)
# GROQ_API_KEY=your_groq_api_key_here

# OpenAI (when SLM_PROVIDER=openai)
# OPENAI_API_KEY=your_openai_api_key_here

# Optional: model name (defaults depend on provider)
# SLM_MODEL=gemini-2.5-flash
# GEMINI_MAX_RPM=3

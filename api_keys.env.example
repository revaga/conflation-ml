# Copy this file to api_keys.env and fill in your keys.
# api_keys.env is gitignored so your keys are not committed.

# --- SLM attribute labeler (scripts/slm_attribute_labeler.py) ---
# Hugging Face only: local (transformers) or huggingface (router API)

# Local: run model on this machine (no API key required for public models)
# SLM_PROVIDER=local
# SLM_MODEL=google/gemma-3-1b-it

# Hugging Face router: needs HF token; model must be supported by your enabled providers
# SLM_PROVIDER=huggingface
# HF_TOKEN=your_huggingface_token_here
# SLM_MODEL=HuggingFaceH4/zephyr-7b-beta
